{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp": "Information"
    }
  },
  "AllowedHosts": "*",
  "Jwt": {
    "Issuer": "myapp-auth",
    "Audience": "myapp-services",
    "SigningKey": "your_super_secret_key_min_32_chars_long_here_change_me_123456789"
  },
  "Services": {
    "AuthService": "http://authservice.webapi:5000",
    "NotificationService": "http://notificationservice.webapi:5000",
    "DataService": "http://dataservice.webapi:5000",
    "MinorTaskService": "http://minortaskservice.webapi:5000",
    "ConfirmationService": "http://confirmationservice.webapi:5000"
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:3000",
      "http://localhost:5173"
    ]
  },
  "ReverseProxy": {
    "Routes": {
      "auth-route": {
        "ClusterId": "auth-cluster",
        "Match": {
          "Path": "/api/auth/{**catch-all}"
        }
      },
      "service-token-route": {
        "ClusterId": "auth-cluster",
        "Match": {
          "Path": "/api/servicetoken/{**catch-all}"
        }
      },
      "notification-hub-route": {
        "ClusterId": "notification-cluster",
        "Match": {
          "Path": "/notificationHub/{**catch-all}"
        }
      },
      "confirmation-route": {
        "ClusterId": "confirmation-cluster",
        "AuthorizationPolicy": "default",
        "Match": {
          "Path": "/api/confirmations/{**catch-all}"
        }
      },
      "data-collections-route": {
        "ClusterId": "data-cluster",
        "AuthorizationPolicy": "default",
        "Match": {
          "Path": "/api/collections/{**catch-all}"
        }
      },
      "data-files-route": {
        "ClusterId": "data-cluster",
        "AuthorizationPolicy": "default",
        "Match": {
          "Path": "/api/files/{**catch-all}"
        }
      },
      "task-statuses-route": {
        "ClusterId": "minortask-cluster",
        "AuthorizationPolicy": "default",
        "Match": {
          "Path": "/api/statuses/{**catch-all}"
        }
      },
      "task-participants-route": {
        "ClusterId": "minortask-cluster",
        "AuthorizationPolicy": "default",
        "Match": {
          "Path": "/api/tasks/{minorTaskId}/participants/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "auth-cluster": {
        "Destinations": {
          "auth-destination": {
            "Address": "http://authservice.webapi:5000"
          }
        }
      },
      "notification-cluster": {
        "Destinations": {
          "notification-destination": {
            "Address": "http://notificationservice.webapi:5000"
          }
        }
      },
      "confirmation-cluster": {
        "Destinations": {
          "confirmation-destination": {
            "Address": "http://confirmationservice.webapi:5000"
          }
        }
      },
      "data-cluster": {
        "Destinations": {
          "data-destination": {
            "Address": "http://dataservice.webapi:5000"
          }
        }
      },
      "minortask-cluster": {
        "Destinations": {
          "minortask-destination": {
            "Address": "http://minortaskservice.webapi:5000"
          }
        }
      }
    }
  }
}
