{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp": "Information"
    }
  },
  "NirbiServiceAuth": {
    "AuthServiceBaseUrl": "http://authservice.webapi:5000",
    "ClientSecret": "2D3adge8MfvfKCdexEx34ne5wXdAbBRVHecQkc6nrgY=",
    "ServiceName": "Gateway Service",
    "Description": "",
    "Scopes": [],
    "ClientId": "gateway-service",
    "TokenRefreshSkewSeconds": 120,
    "ServiceJwt": {
      "Issuer": "myapp-auth",
      "Audience": "myapp-services",
      "SigningKey": "your_super_secret_key_min_32_chars_long_here_change_me_123456789"
    },
    "Keycloak": {
      "Authority": "http://keycloak:8080/realms/nirbi",
      "Audience": "nirbi",
      "RequireHttpsMetadata": false
    }
  },
  "AllowedHosts": "*",
  "Jwt": {
    "Issuer": "myapp-auth",
    "Audience": "myapp-services",
    "SigningKey": "your_super_secret_key_min_32_chars_long_here_change_me_123456789"
  },
  "Services": {
    "AuthService": "http://authservice.webapi:5000",
    "NotificationService": "http://notificationservice.webapi:5000",
    "DataService": "http://dataservice.webapi:5000",
    "MinorTaskService": "http://minortaskservice.webapi:5000",
    "ConfirmationService": "http://confirmationservice.webapi:5000",
    "CommunicationService": "http://communicationservice.webapi:5000"
  },
  "Cors": {
    "AllowedOrigins": [
      "http://apigateway:3000",
      "http://apigateway:5173"
    ]
  },
  "ReverseProxy": {
    "Routes": {
      "auth-route": {
        "ClusterId": "auth-cluster",
        "Match": {
          "Path": "/api/auth/{**catch-all}"
        }
      },
      "service-token-route": {
        "ClusterId": "auth-cluster",
        "Match": {
          "Path": "/api/servicetoken/{**catch-all}"
        }
      },
      "users-route": {
        "ClusterId": "auth-cluster",
        "Match": {
          "Path": "/api/users/{**catch-all}"
        }
      },
      "notification-hub-route": {
        "ClusterId": "notification-cluster",
        "Match": {
          "Path": "/notificationHub/{**catch-all}"
        }
      },
      "confirmation-route": {
        "ClusterId": "confirmation-cluster",
        "AuthorizationPolicy": "authenticated",
        "Match": {
          "Path": "/api/confirmations/{**catch-all}"
        }
      },
      "data-collections-route": {
        "ClusterId": "data-cluster",
        "AuthorizationPolicy": "authenticated",
        "Match": {
          "Path": "/api/collections/{**catch-all}"
        }
      },
      "data-files-route": {
        "ClusterId": "data-cluster",
        "AuthorizationPolicy": "authenticated",
        "Match": {
          "Path": "/api/files/{**catch-all}"
        }
      },
      "task-statuses-route": {
        "ClusterId": "minortask-cluster",
        "AuthorizationPolicy": "authenticated",
        "Match": {
          "Path": "/api/statuses/{**catch-all}"
        }
      },
      "task-participants-route": {
        "ClusterId": "minortask-cluster",
        "AuthorizationPolicy": "authenticated",
        "Match": {
          "Path": "/api/tasks/{minorTaskId}/participants/{**catch-all}"
        }
      },
      "chats-route": {
        "ClusterId": "communication-cluster",
        "AuthorizationPolicy": "authenticated",
        "Match": {
          "Path": "/api/chats"
        }
      },
      "chats-sub-route": {
        "ClusterId": "communication-cluster",
        "AuthorizationPolicy": "authenticated",
        "Match": {
          "Path": "/api/chats/{**catch-all}"
        }
      },
      "chat-users-route": {
        "ClusterId": "communication-cluster",
        "AuthorizationPolicy": "authenticated",
        "Match": {
          "Path": "/api/chat/{**catch-all}"
        }
      },
      "messages-route": {
        "ClusterId": "communication-cluster",
        "AuthorizationPolicy": "authenticated",
        "Match": {
          "Path": "/api/Messages"
        }
      },
      "messages-sub-route": {
        "ClusterId": "communication-cluster",
        "AuthorizationPolicy": "authenticated",
        "Match": {
          "Path": "/api/Messages/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "auth-cluster": {
        "Destinations": {
          "auth-destination": {
            "Address": "http://authservice.webapi:5000"
          }
        }
      },
      "notification-cluster": {
        "Destinations": {
          "notification-destination": {
            "Address": "http://notificationservice.webapi:5000"
          }
        }
      },
      "confirmation-cluster": {
        "Destinations": {
          "confirmation-destination": {
            "Address": "http://confirmationservice.webapi:5000"
          }
        }
      },
      "data-cluster": {
        "Destinations": {
          "data-destination": {
            "Address": "http://dataservice.webapi:5000"
          }
        }
      },
      "minortask-cluster": {
        "Destinations": {
          "minortask-destination": {
            "Address": "http://minortaskservice.webapi:5000"
          }
        }
      },
      "communication-cluster": {
        "Destinations": {
          "communication-destination": {
            "Address": "http://communicationservice.webapi:5000"
          }
        }
      }
    }
  }
}