{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ExternalServicesOptions": {
    "KafkaAddress": "localhost:9092",
    "SchemaRegistryAddress": "localhost:8081",
    "ConfirmationServiceTopic": "confirmation-service",
    "MinorTaskServiceTopic": "minor-task-service",
    "NotificationServiceTopic": "notification-service"
  },
  "KafkaConsumersOptions": {
    "GroupId": "NotificationService",
    "AutoOffsetReset": "Earliest",
    "EnableAutoCommit": "true"
  },
  "DataTypesOptins": {
    "DecimalScale": 10,
    "DecimalPrecision": 10
  },
  "ContentTypesOptions": {
    "Json": "application/json"
  },
    "NirbiServiceAuth": {
        "AuthServiceBaseUrl": "http://authservice.webapi:5000",
        "ClientId": "notification-service",
        "ServiceName": "Notification Service",
        "Description": "",
        "Scopes": [],
        "ClientSecret": "",
        "TokenRefreshSkewSeconds": 120,
        "ServiceJwt": {
            "Issuer": "myapp-auth",
            "Audience": "myapp-services",
            "SigningKey": "your_super_secret_key_min_32_chars_long_here_change_me_123456789"
        },
        "Keycloak": {
            "Authority": "http://keycloak:8080/realms/nirbi",
            "Audience": "nirbi",
            "RequireHttpsMetadata": false
        }
    }
}
