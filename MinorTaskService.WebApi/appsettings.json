{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "PostgreSql": "Server=localhost;Database=minor_tasks;User Id=postgres;Password=postgres_password;"
  },
  "ExternalServicesOptions": {
    "CommunicationServiceAddress": "http://localhost:5001",
    "KafkaAddress": "localhost:9092",
    "SchemaRegistryAddress": "http://localhost:8081",
    "MinorTaskServiceTopic": "minor-tasks",
    "TaskParticipantServiceTopic": "task-participants"
  },
  "DefaultDataOptions": {
    "GetMinorTaskLimit": 20,
    "GetMinorTaskBetweenFrom": 21,
    "GetMinorTaskBetweenTo": 40
  },
  "NirbiServiceAuth": {
    "AuthServiceBaseUrl": "http://localhost:5000",
    "ClientId": "minor-task-service",
    "ClientSecret": "",
    "TokenRefreshSkewSeconds": 120,
    "ServiceJwt": {
      "Issuer": "myapp-auth",
      "Audience": "myapp-services",
      "SigningKey": "your_super_secret_key_min_32_chars_long_here_change_me_123456789"
    }
  }
}
