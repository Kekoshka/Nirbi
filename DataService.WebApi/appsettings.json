{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "PostgreSql": "Server=localhost;Database=data_service;User Id=postgres;Password=postgres_password;"
  },
  "S3Storage": {
    "BucketName": "nirbi-data",
    "ServiceUrl": "http://localhost:9000",
    "AccessKey": "minioadmin",
    "SecretKey": "minioadmin",
    "Region": "us-east-1",
    "ForcePathStyle": true
  },
  "NirbiServiceAuth": {
    "ServiceJwt": {
      "Issuer": "myapp-auth",
      "Audience": "myapp-services",
      "SigningKey": "your_super_secret_key_min_32_chars_long_here_change_me_123456789"
    }
  }
}
